+// WIP112: decide whether the selected /data backup needs a lockscreen credential (PIN/password)
+// before restore, and route the GUI accordingly. Runs in the CALLER thread (registered in the
+// non-threaded action block), so gui_changePage to restore_run/fbe_restore_pin does NOT collide
+// with the nandroid restore thread ("Another threaded action is already running"). The credential
+// is needed iff the backup's data archive carries a synthetic-password protector with a real
+// credential - i.e. a "system_de/0/spblob/<handle>.pwd" entry exists in data.f2fs.win (an
+// empty-LSKF device has only .weaver/.spblob, no .pwd). We probe with `tar -tf | grep` over the
+// archive HEADERS only (filenames), which is cheap (~0.4s, no payload read). If a credential is
+// present we show fbe_restore_pin (our OWN keyboard page; it does NOT use the broken native FBE
+// decrypt). Otherwise we go straight to restore_run. The actual CE unlock is done later by the
+// staged de_keyinstall in partition.cpp::Restore_Tar using tw_fbe_pin.
+int GUIAction::fbe_pin_check(std::string arg __unused)
+{
+	string Restore_Path;
+	DataManager::GetValue("tw_restore", Restore_Path);
+	// Always clear any stale credential first.
+	DataManager::SetValue("tw_fbe_pin", "");
+	DataManager::SetValue("tw_fbe_need_pin", 0);
+
+	// Find the data archive (data.f2fs.win, possibly split data.f2fs.win000).
+	string data_archive;
+	if (TWFunc::Path_Exists(Restore_Path + "/data.f2fs.win"))
+		data_archive = Restore_Path + "/data.f2fs.win";
+	else if (TWFunc::Path_Exists(Restore_Path + "/data.f2fs.win000"))
+		data_archive = Restore_Path + "/data.f2fs.win000";
+
+	bool need_pin = false;
+	if (!data_archive.empty()) {
+		// List archive entries and look for a credential protector (.pwd in spblob).
+		// Header-only scan; grep -m1 stops at the first match.
+		string cmd = "tar -tf '" + data_archive + "' 2>/dev/null | grep -m1 -E 'system_de/0/spblob/.*\\.pwd$'";
+		string result;
+		TWFunc::Exec_Cmd(cmd, result, false);
+		if (!result.empty()) {
+			need_pin = true;
+			LOGINFO("WIP112: backup has a lockscreen credential (.pwd found: %s) -> prompting for PIN\n", result.c_str());
+		} else {
+			LOGINFO("WIP112: no credential in backup (empty LSKF) -> no PIN prompt\n");
+		}
+	} else {
+		LOGINFO("WIP112: no data archive found in '%s' - skipping PIN prompt\n", Restore_Path.c_str());
+	}
+
+	if (need_pin) {
+		DataManager::SetValue("tw_fbe_need_pin", 1);
+		DataManager::SetValue("tw_password_fail", 0);
+		gui_changePage("fbe_restore_pin");
+	} else {
+		gui_changePage("restore_run");
+	}
+	return 0;
+}
