+#ifdef TW_INCLUDE_CRYPTO
+// WIP107(redo): populate the in-process fscrypt key maps that libtar consults when it
+// backs up / restores FBE encryption policies:
+//   - lookup_ref_key()  (libtar/append.c, BACKUP)  translates a directory's live 16-byte
+//     key identifier -> the symbolic policy ref ("2DK"/"2DE0"/"2CE0") written into the tar.
+//   - lookup_ref_tar()  (libtar/extract.c, RESTORE) translates that symbolic ref back to the
+//     CURRENT 16-byte identifier before FS_IOC_SET_ENCRYPTION_POLICY.
+// Both read three globals (de_key_raw_ref / s_de_policies / s_ce_policies, fscrypt-common.h).
+// On pa1q (A16) these are normally EMPTY: native Decrypt_DE/Decrypt_User go through keystore2
+// /KeyMint which is A16-incompatible, so they never populate the maps -> backup silently drops
+// every policy (fep=NULL) and restore never even calls lookup_ref_tar. The earlier WIP107
+// "fix" called those same broken Decrypt_* functions and so could never work.
+//
+// Instead decrypt.sh (TWRP boot) runs de_keyinstall, which installs all three FBE key layers
+// into the kernel keyring via FS_IOC_ADD_ENCRYPTION_KEY and writes the resulting 16-byte kernel
+// identifiers to /tmp/.fbe_keyids ("DK <hex32>" / "DE0 <hex32>" / "CE0 <hex32>"). Those kernel
+// identifiers are exactly what belongs in key_raw_ref (verified on-device: keyring id == the
+// directory's master_key_identifier == FS_IOC_ADD_ENCRYPTION_KEY return). We inject them
+// directly with NO keystore call. lookup_ref_key/lookup_ref_tar read only .key_raw_ref, so
+// leaving EncryptionPolicy.options at its default is fine. Idempotent; no-op if file absent.
+static int hexnyb(char c) {
+	if (c >= '0' && c <= '9') return c - '0';
+	if (c >= 'a' && c <= 'f') return c - 'a' + 10;
+	if (c >= 'A' && c <= 'F') return c - 'A' + 10;
+	return -1;
+}
+static void inject_fbe_maps() {
+	FILE *f = fopen("/tmp/.fbe_keyids", "r");
+	if (!f) {
+		LOGINFO("inject_fbe_maps: /tmp/.fbe_keyids absent - native FBE policy backup/restore inactive\n");
+		return;
+	}
+	char line[128];
+	int n = 0;
+	while (fgets(line, sizeof(line), f)) {
+		char type[8] = {0}, hexid[64] = {0};
+		if (sscanf(line, "%7s %63s", type, hexid) != 2)
+			continue;
+		if (strlen(hexid) != 32)  // must be exactly 16 bytes (v2 identifier)
+			continue;
+		std::string raw;
+		raw.reserve(16);
+		bool ok = true;
+		for (int i = 0; i < 32; i += 2) {
+			int hi = hexnyb(hexid[i]), lo = hexnyb(hexid[i + 1]);
+			if (hi < 0 || lo < 0) { ok = false; break; }
+			raw.push_back((char)((hi << 4) | lo));
+		}
+		if (!ok || raw.size() != 16)
+			continue;
+		if (strcmp(type, "DK") == 0) { de_key_raw_ref = raw; n++; }
+		else if (strcmp(type, "DE0") == 0) { s_de_policies[0].key_raw_ref = raw; n++; }
+		else if (strcmp(type, "CE0") == 0) { s_ce_policies[0].key_raw_ref = raw; n++; }
+	}
+	fclose(f);
+	LOGINFO("inject_fbe_maps: injected %d FBE key identifier(s) into libtar policy maps\n", n);
+}
+#endif
