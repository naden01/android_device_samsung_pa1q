+// WIP110 (staged FBE restore): extract only entries whose path starts with one of `prefixes`,
+// in-process. On metadata-encrypted /data the kernel keyring is EMPTY right after Format, but
+// libtar's main pass applies an fscrypt policy to each freshly-created dir; writing files INTO an
+// encrypted dir whose key is not in the keyring fails with ENOKEY (observed:
+// "tar_extract_file failed /data/vendor/hardware" -> ERROR 255). The fix is to load the FBE keys
+// BEFORE the main pass, but the key material itself lives in the archive. So we first pull only
+// the small key-material trees out (this method), run de_keyinstall, then do the normal full
+// extractTarFork(). No fork/pipe/progress: the matched data is a few MB and runs fast.
+//
+// We do prefix matching (NOT fnmatch): tar_extract_glob uses FNM_PATHNAME where '*' does not cross
+// '/', so it cannot match a whole subtree recursively, and it takes only ONE pattern per call.
+// We need several whole subtrees (e.g. "misc/", "system_de/") plus a single file
+// ("system/locksettings.db") in a single archive pass, so we walk entries ourselves and reuse
+// libtar's native tar_extract_file (which handles mkdir, fscrypt policy and SELinux per entry).
+// Archive paths are stored WITHOUT a leading '/' (TWRP strips it on backup), so prefixes here are
+// given without a leading '/' too (e.g. "misc/", "unencrypted/"). Returns 0 on read-to-EOF, -1 on error.
+int twrpTar::extractGlob(const std::vector<std::string>& prefixes) {
+	char* charRootDir = (char*) tardir.c_str();
+	if (!part_settings->adbbackup)
+		Set_Archive_Type(TWFunc::Get_File_Type(tarfn));
+	else
+		current_archive_type = (part_settings->adb_compression == 1) ? COMPRESSED : UNCOMPRESSED;
+	if (current_archive_type == ENCRYPTED || current_archive_type == COMPRESSED_ENCRYPTED) {
+		int dret = TWFunc::Try_Decrypting_File(tarfn, password);
+		if (dret < 2) {
+			LOGINFO("extractGlob: cannot decrypt '%s'\n", tarfn.c_str());
+			return -1;
+		}
+		if (dret == 3)
+			current_archive_type = COMPRESSED_ENCRYPTED;
+	}
+	if (openTar() == -1)
+		return -1;
+
+	int i, dummy_fd = 0, rc = 0, matched = 0;
+	while ((i = th_read(t)) == 0) {
+		char* filename = th_get_pathname(t);
+		// strip a leading '/' if present so comparison is consistent
+		const char* fn = (filename && filename[0] == '/') ? filename + 1 : filename;
+		bool want = false;
+		for (size_t p = 0; p < prefixes.size(); ++p) {
+			const std::string& pre = prefixes[p];
+			if (strncmp(fn, pre.c_str(), pre.size()) == 0) { want = true; break; }
+		}
+		if (!want) {
+			if (TH_ISREG(t) && tar_skip_regfile(t) != 0) { rc = -1; break; }
+			continue;
+		}
+		string realname = string(charRootDir) + "/" + fn;
+		if (tar_extract_file(t, realname.c_str(), charRootDir, &dummy_fd) != 0) {
+			LOGINFO("extractGlob: failed to extract '%s'\n", realname.c_str());
+			rc = -1;
+			break;
+		}
+		matched++;
+	}
+	if (i == -1)
+		rc = -1;
+	LOGINFO("extractGlob: extracted %d entr%s for %zu prefix(es), rc=%d\n",
+	        matched, matched == 1 ? "y" : "ies", prefixes.size(), rc);
+	if (tar_close(t) != 0)
+		LOGINFO("extractGlob: unable to close tar file\n");
+	return rc;
+}
