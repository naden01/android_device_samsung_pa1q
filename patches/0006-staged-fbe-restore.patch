+
+			// Stage 2: user-0 DE + keystore + CE material under /data/misc (now DK-readable)
+			//          -> install DE0 -> inject DK+DE0
+			stage.clear();
+			stage.push_back("misc/");
+			tar.extractGlob(stage);
+			TWFunc::Exec_Cmd(de_keyinstall, kresult, true);
+			LOGINFO("WIP110 stage2 (DE0) de_keyinstall:\n%s\n", kresult.c_str());
+			inject_fbe_maps();
+
+			// Stage 3: CE synthetic-password material (now DE0-readable) -> install CE0
+			//          -> inject DK+DE0+CE0
+			// NOTE: use the "system/" DIRECTORY prefix, NOT "system/locksettings.db" (a file).
+			// A file prefix makes libtar create the parent /data/system via a bare mkdir with NO
+			// fscrypt policy; the main pass then hits EEXIST and skips the policy, leaving
+			// /data/system unencrypted -> Android init "set_policy_failed:/data/system" -> bootloop.
+			// The "system/" prefix extracts the /system/ dir entry itself (pax tag 2DK), so the dir
+			// is created WITH its policy (DK is already in the keyring from stage1). Trailing slash
+			// avoids matching siblings system_de/ system_ce/ (those start with "system_", not "system/").
+			stage.clear();
+			stage.push_back("system_de/");
+			stage.push_back("system/");
+			tar.extractGlob(stage);
+			TWFunc::Exec_Cmd(de_keyinstall, kresult, true);
+			LOGINFO("WIP110 stage3 (CE0) de_keyinstall:\n%s\n", kresult.c_str());
+			inject_fbe_maps();
+		} else {
+			LOGINFO("WIP110: %s not found - skipping staged key preload (restore may fail with ENOKEY)\n", de_keyinstall.c_str());
+		}
+	}
+#endif
+
