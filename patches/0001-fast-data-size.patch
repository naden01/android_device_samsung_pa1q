From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: pa1q device tree <noreply@local>
Date: Tue, 24 Jun 2026 00:00:00 +0000
Subject: [PATCH] twrp: fast statfs-only /data+system size refresh via ORS (no GUI freeze)

PROBLEM
  TWRP computes partition sizes ONCE at startup (Update_System_Details), which on
  the S25 (pa1q) runs BEFORE decrypt.sh has mounted /data -> Size=Free=0 -> "Internal
  Storage (0 MB)" forever. The only recompute (Refresh Sizes button) calls
  Get_Folder_Size() (a recursive walk of all of /data) -> 3-5s GUI freeze.
  Storage size itself (Size/Used/Free) is cheap via statfs(); only the
  Get_Folder_Size() backup estimate is slow, and the two are glued in one function.

FIX (additive; auto-applied at build via vendorsetup, auto-revertable via git checkout)
  - partitions.hpp: declare TWPartitionManager::Update_Data_Size_Fast().
  - partitionmanager.cpp: implement it - statfs() on /data and the mounted system
    partition, writing BOTH the DataManager display vars (tw_storage_free_size /
    tw_backup_data_size / tw_backup_system_size) AND the live TWPartition fields
    (Size/Used/Free/Backup_Size) that the Select-Storage / Backup dropdowns read.
    No Get_Folder_Size -> zero freeze. (TWPartitionManager is a friend of TWPartition.)
  - gui/gui.cpp: handle a new ORS word "refreshdatasz" at the TOP of ors_command_read(),
    BEFORE fopen(ORS_OUTPUT_FILE,"w"). That fopen blocks until a reader opens the orsout
    FIFO, which a bare `echo refreshdatasz > /system/bin/orsin` (our scripts) never does
    -> GUI hang. Handling it first and returning (the command writes no reply) avoids it.

  decrypt.sh / remount_data send `echo refreshdatasz > /system/bin/orsin` after a
  successful mount. Freeze-free on both first decrypt and GUI remount. "Internal
  Storage" IS the /data partition (Setup_Data_Media), so updating dat->Free fixes
  the storage dropdown directly.

  Files (for revert): bootable/recovery/{partitions.hpp,partitionmanager.cpp,gui/gui.cpp}
---
diff --git a/gui/gui.cpp b/gui/gui.cpp
index 874cdd9..91508ee 100644
--- a/gui/gui.cpp
+++ b/gui/gui.cpp
@@ -460,6 +460,14 @@ static void ors_command_read()
 		command[1022] = '\n';
 		command[1023] = '\0';
 		LOGINFO("Command '%s' received\n", command);
+		// pa1q: handle our self-contained size-refresh word BEFORE opening the orsout
+		// FIFO. fopen(orsout,"w") below blocks until a reader opens orsout, which a bare
+		// `echo refreshdatasz > orsin` (decrypt.sh/remount_data) never does -> GUI hang.
+		// This command writes no reply, so run it here and return; orsout is untouched.
+		if (strncmp(command, "refreshdatasz", 13) == 0) {
+			PartitionManager.Update_Data_Size_Fast();
+			return;
+		}
 		orsout = fopen(ORS_OUTPUT_FILE, "w");
 		if (!orsout) {
 			close(ors_read_fd);
diff --git a/partitionmanager.cpp b/partitionmanager.cpp
index 2766b4c..077097e 100644
--- a/partitionmanager.cpp
+++ b/partitionmanager.cpp
@@ -1953,6 +1953,42 @@ void TWPartitionManager::Update_System_Details(void) {
 	return;
 }
 
+// pa1q: statfs-only refresh of /data (and the mounted system partition) sizes.
+// Updates both the DataManager display vars AND the live TWPartition size fields
+// (Select-Storage / Backup dropdowns read the live fields), WITHOUT the recursive
+// Get_Folder_Size() walk that Update_System_Details() does - so there is no GUI
+// freeze. Triggered by the "refreshdatasz" ORS word after decrypt.sh / remount_data
+// mount /data. TWPartitionManager is a friend of TWPartition (see partitions.hpp).
+void TWPartitionManager::Update_Data_Size_Fast(void) {
+	struct statfs st;
+	TWPartition* dat = Find_Partition_By_Path("/data");
+	if (dat != NULL && dat->Is_Mounted() && statfs("/data/.", &st) == 0) {
+		dat->Size = (st.f_blocks * st.f_bsize);
+		dat->Free = (st.f_bfree * st.f_bsize);
+		dat->Used = ((st.f_blocks - st.f_bfree) * st.f_bsize);
+		dat->Backup_Size = dat->Used;
+		DataManager::SetValue(TW_BACKUP_DATA_SIZE, (int)(dat->Used / 1048576LLU));
+		DataManager::SetValue(TW_STORAGE_FREE_SIZE, (int)(dat->Free / 1048576LLU));
+		LOGINFO("Update_Data_Size_Fast: /data used=%iMB free=%iMB\n",
+			(int)(dat->Used / 1048576LLU), (int)(dat->Free / 1048576LLU));
+	} else {
+		LOGINFO("Update_Data_Size_Fast: /data not mounted - skipped\n");
+	}
+	// System partition size (cheap statfs of the mounted system root), if present.
+	TWPartition* sys = Find_Partition_By_Path(Get_Android_Root_Path());
+	if (sys != NULL && sys->Is_Mounted()) {
+		string sys_path = sys->Mount_Point + "/.";
+		if (statfs(sys_path.c_str(), &st) == 0) {
+			sys->Size = (st.f_blocks * st.f_bsize);
+			sys->Free = (st.f_bfree * st.f_bsize);
+			sys->Used = ((st.f_blocks - st.f_bfree) * st.f_bsize);
+			sys->Backup_Size = sys->Used;
+			DataManager::SetValue(TW_BACKUP_SYSTEM_SIZE, (int)(sys->Used / 1048576LLU));
+		}
+	}
+	return;
+}
+
 void TWPartitionManager::Post_Decrypt(const string& Block_Device) {
 	TWPartition* dat = Find_Partition_By_Path("/data");
 
