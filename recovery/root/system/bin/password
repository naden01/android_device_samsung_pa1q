#!/system/bin/sh
# password  -  unlock the user-0 CE layer (/data/data, /data/media) with the lockscreen
# credential, from the TWRP Terminal. metadata + DE are already mounted by decrypt.sh at
# boot (no credential needed); only CE waits for the PIN/password.
#
# TWO WAYS TO USE IT:
#   1) argument mode:     password 'MyP@ss!'      (single-quote special chars)
#   2) interactive mode:  password                (then type the password and press Enter)
#
# Interactive mode reads the WHOLE line RAW (IFS= read -r): every special character is taken
# exactly as typed - the TWRP shell never parses it, so NO "syntax error / unknown command"
# can ever happen no matter what you type. The verbose internals are swallowed; only one of
# two clean results is printed.

# ----- get the credential (arg mode rejoins all args; else interactive raw read) -----
if [ "$#" -ge 1 ]; then
    PIN="$*"
else
    printf "Enter PIN / password (visible), then press Enter: "
    IFS= read -r PIN
fi

# ----- clean single-line verdicts -----
say()  { echo "$*"; }
PASS_OK="==================================================
  OK:  PASSWORD ACCEPTED - data partition DECRYPTED.
       /data/data and /data/media are now open.
=================================================="
PASS_BAD="==================================================
  X:   WRONG PASSWORD - data NOT decrypted.
=================================================="

if [ -z "$PIN" ]; then
    say "no credential entered.  use:  password <pin>   or just:  password"
    exit 1
fi

# preconditions (quiet - never leak shell noise)
if ! grep -qE " /data " /proc/mounts 2>/dev/null; then
    say "ERROR: /data not mounted - reboot recovery so the auto-decrypt mounts it first."
    exit 1
fi
SYS=/decrypt
LK="$SYS/system/bin/bootstrap/linker64"
LIBS="$SYS/system/lib64/bootstrap:$SYS/system/lib64:/vendor/lib64:/vendor/lib64/hw"
if [ ! -e "$LK" ]; then
    say "ERROR: A16 stack not mounted ($LK missing) - reboot recovery."
    exit 1
fi

# Run de_keyinstall <credential> via the A16 bootstrap linker. ALL of its output (stdout AND
# stderr) is captured into OUT so nothing leaks to the terminal - the full verbose log still
# goes to logcat for diagnostics. Only the clean verdict below reaches the screen.
OUT=$( ( export LD_LIBRARY_PATH="$LIBS" ANDROID_DATA=/data ANDROID_ROOT=/system
         exec "$LK" /system/bin/de_keyinstall "$PIN" ) 2>&1 )

echo ""
if echo "$OUT" | grep -q "CE LAYER UNLOCKED"; then
    say "$PASS_OK"
    exit 0
fi
say "$PASS_BAD"
if echo "$OUT" | grep -qiE "throttl|timeout=[1-9]"; then
    say "  (too many wrong tries -> Weaver throttle; wait, then retry the correct password)"
fi
exit 1
