#!/system/bin/sh
# password <PIN-or-password>
# Unlock the user-0 CE layer (/data/data, /data/media) with the real lockscreen credential,
# from the TWRP Terminal. The metadata + DE layers are already mounted automatically by
# decrypt.sh at boot (no credential needed); only the CE step waits for the PIN. Re-running
# de_keyinstall re-installs the (idempotent, per-boot) DE keys and then does the CE step with
# the supplied credential -> scrypt -> weaver -> synthetic password -> fbe key -> CE key.
#
# Usage in the TWRP terminal:   password 123456
PIN="$1"
if [ -z "$PIN" ]; then
    echo "usage: password <PIN-or-password>"
    exit 1
fi
if ! grep -qE " /data " /proc/mounts 2>/dev/null; then
    echo "ERROR: /data is not mounted. Reboot recovery so the auto-decrypt mounts it first."
    exit 1
fi

SYS=/decrypt
LK="$SYS/system/bin/bootstrap/linker64"
LIBS="$SYS/system/lib64/bootstrap:$SYS/system/lib64:/vendor/lib64:/vendor/lib64/hw"
if [ ! -e "$LK" ]; then
    echo "ERROR: the A16 stack is not mounted ($LK missing). Reboot recovery."
    exit 1
fi

# Run the A16 de_keyinstall through the bootstrap linker (same env as decrypt.sh's lrun),
# passing the credential. Capture its output so we can show a clean verdict.
OUT=$( ( export LD_LIBRARY_PATH="$LIBS" ANDROID_DATA=/data ANDROID_ROOT=/system
         exec "$LK" /system/bin/de_keyinstall "$PIN" ) 2>&1 )
echo "$OUT"

echo ""
echo "==================================================================="
if echo "$OUT" | grep -q "CE LAYER UNLOCKED"; then
    echo "  OK: PIN accepted - data partition decrypted."
    echo "      /data/data and /data/media are now open."
elif echo "$OUT" | grep -qE "weaver read not OK|INCORRECT_KEY|status=2"; then
    echo "  FAIL: wrong PIN/password - data NOT decrypted."
    echo "        (wrong attempts trigger a Weaver throttle - wait before retrying)"
elif echo "$OUT" | grep -qE "throttl|timeout=[1-9]"; then
    echo "  THROTTLED: too many wrong attempts - wait, then retry with the correct PIN."
else
    echo "  FAIL: could not decrypt - see the log above."
fi
echo "  fscrypt keyring: $(cat /proc/keys 2>/dev/null | grep -c fscrypt) key(s)"
echo "==================================================================="
