#!/system/bin/sh
# Auto-remount watcher. Started by decrypt.sh ONLY after the FIRST successful /data mount, so
# every boot-time mount failure already in recovery.log is in the baseline and ignored.
#
# TWRP 12.1 cannot mount the A16 FBE /data itself (its fstab /data device is the raw, still-
# encrypted partition), so once the user unmounts /data via the GUI they can't get it back
# without a reboot. This watcher fixes that: when /data is unmounted AND the user then presses
# Mount in the GUI (TWRP tries the raw device and logs "Unable to mount '/data'" / "Failed to
# mount '/data'"), we remount the persistent dm-default-key device and re-install the FBE keys
# (remount_data). A busy/failed UNMOUNT leaves /data mounted, so it never triggers a remount.
RLOG=/tmp/recovery.log
PAT="Unable to mount '/data'|Failed to mount '/data'"

count() { c=$(grep -cE "$PAT" "$RLOG" 2>/dev/null); [ -z "$c" ] && c=0; echo "$c"; }
base=$(count)

# Poll /proc/mounts tightly (0.1s) so a GUI "Mount" tap is caught fast (~0.2-0.3s to mounted,
# vs ~1-2s with the old `sleep 2`). The heavy grep of recovery.log runs only WHILE /data is
# unmounted; while mounted we just refresh the baseline ~every 2s. /proc/mounts is a pseudo-file
# (no I/O) so the tight poll is cheap.
i=0
while true; do
    sleep 0.1
    if grep -qE " /data " /proc/mounts 2>/dev/null; then
        i=$((i + 1)); [ "$((i % 20))" -eq 0 ] && base=$(count)
        continue
    fi
    i=0
    # /data is unmounted - did the user just press Mount (a NEW mount-fail line)?
    cur=$(count)
    if [ "$cur" -gt "$base" ]; then
        /system/bin/remount_data >/tmp/remount_watcher.log 2>&1
        base=$(count)
    fi
done
