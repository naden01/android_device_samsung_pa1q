on init
    # to cut charging battery path
    write /sys/class/power_supply/battery/siop_level 0
	
on init
    write /sys/class/backlight/panel0-backlight/brightness 200
    setprop sys.usb.configfs 1
    setprop ro.twrp.vendor_boot true
    setprop ro.twrp.fastbootd 1
    setprop ro.boot.fastbootd false

on property:ro.boot.usbcontroller=*
    setprop sys.usb.controller ${ro.boot.usbcontroller}
    wait /sys/bus/platform/devices/${ro.boot.usb.dwc3_msm:-a600000.ssusb}/mode
    write /sys/bus/platform/devices/${ro.boot.usb.dwc3_msm:-a600000.ssusb}/mode peripheral
    wait /sys/class/udc/${ro.boot.usbcontroller} 1

on fs
    wait /dev/block/platform/soc/${ro.boot.bootdevice}
    symlink /dev/block/platform/soc/${ro.boot.bootdevice} /dev/block/bootdevice
	
	# Mount firmware
    # apnhlos is mounted FIRST here, so it owns the vfat superblock - vfat has no
    # on-disk unix perms and a second mount of the same device reuses this sb's
    # options, so perms MUST be set right here. A bare `mount vfat` inherits init's
    # umask -> skeymast.mbn lands 0700 root:root, and the Samsung keymint_tee HAL runs
    # as user *system*: it then can't open the TA ("Failed to open skeymast.mbn" ->
    # nwd_tz_open failed -> createOperation -49 SECURE_HW_COMMUNICATION_FAILED ->
    # /data metadata decrypt fails, fail_cause M02R). Use the stock fstab.qcom options:
    # root:system, owner/group-readable (files 0440, dirs 0550).
    mkdir /vendor/firmware_mnt
    mount vfat /dev/block/bootdevice/by-name/apnhlos /vendor/firmware_mnt ro uid=0,gid=1000,fmask=337,dmask=227,context=u:object_r:firmware_file:s0,shortname=lower

    # Wait for vendor partition to be available
    wait /dev/block/platform/soc/${ro.boot.bootdevice}/by-name/vendor
    
    # Create vendor monitoring directory
    mkdir /tmp/vendor_monitor 0755 root root

    export ANDROID_ROOT /system_root

    # Start vendor partition monitoring early for faster boot
    exec - root root -- /system/bin/vendor_check.sh 
   
    
# Set vendor monitoring properties
    setprop vendor.twrp.vendor_check_complete true



# Vendor partition check service
service vendor-check /system/bin/vendor_check.sh
    class main
    user root
    group root
    oneshot
    disabled

# Vendor partition health check service
service vendor-health /system/bin/vendor_health.sh
    class main
    user root
    group root
    oneshot
    disabled



on property:vendor.twrp.monitoring=true
    start vendor-check
    start vendor-health

# Manual vendor monitoring commands
on property:vendor.twrp.manual_check=true
    exec - root root -- /system/bin/vendor_check.sh &
    exec - root root -- /system/bin/vendor_health.sh &



on post-fs
    start boot-hal-1-2


on boot
    start health-hal-2-1

    # Release Samsung USB Secure Lock so USB-OTG mode works in recovery
    wait /sys/class/usb_notify/usb_control/usb_sl 5
    write /sys/class/usb_notify/usb_control/usb_sl SUNNY_WORK_MODE

    # AUTO-START the A16 decrypt at boot (no manual setprop needed). decrypt.sh waits
    # for TWRP to map the super partitions + a short settle before it swaps in the A16
    # servicemanager, so this does not race TWRP's own startup.
    setprop twrp.decrypt.run 1

# A16 decrypt: run the WHOLE Android-16 security stack from the dump, one version
# (the A12 wall was: A16 KeyMint can't register in the A12 servicemanager). The stack
# lives under /decrypt (NOT /mnt - vold tears down /mnt mounts). Auto-started above;
# can also be re-triggered manually:  setprop twrp.decrypt.run 1
on property:twrp.decrypt.run=1
    mkdir /mnt/vendor/efs/DAK 0775 system system
    chown system system /mnt/vendor/efs/DAK/gakkeybox
    chmod 0644 /mnt/vendor/efs/DAK/gakkeybox
    mkdir /data/vendor/keymaster 0775 system system
    start decrypt

# Oneshot orchestrator: mount dump -> VINTF overlay -> stop A12 sm/keystore2 ->
# start the A16 stack below -> drive the metadata decrypt via the matched A16 vdc.
service decrypt /system/bin/decrypt.sh
    class main
    user root
    group root system
    seclabel u:r:recovery:s0
    oneshot
    disabled

# A16 servicemanager - claims /dev/binder once the orchestrator stops the A12 one.
# MUST run as user ROOT: as user system it SIGABRTs immediately (cannot become the
# binder context manager / set servicemanager.ready). Confirmed live - as root it is
# stable and sets servicemanager.ready=true; as system it crash-loops on signal 6.
service decrypt-servicemanager /system/bin/hal_run.sh /decrypt/system/bin/servicemanager
    class core
    user root
    group root readproc
    seclabel u:r:recovery:s0
    disabled

# apexservice stub - keystore2 blocks on waitForService("apexservice") during startup
# (calls IApexService.getActivePackages()); the real apexd can't run in recovery (it
# crashes on apex activation). This tiny native service (built from device tree, NOT
# the dump) registers the name and returns an empty package list so keystore2 finishes
# startup and registers IKeystoreService. Built against libbinder_ndk and run THROUGH
# hal_run.sh (bootstrap linker + the A16 libbinder_ndk.so from the dump): the C++
# libbinder addService wire format is not A12<->A16 stable and the A16 servicemanager
# rejected the A12-marshalled call EX_BAD_PARCELABLE. Verified live 2026-06-14: this
# wait blocked the whole decrypt chain.
service decrypt-apexservice /system/bin/hal_run.sh /system/bin/apexservice_stub
    class core
    user root
    group system
    seclabel u:r:recovery:s0
    disabled

# qseecomd - stock notify-topology socket + root/drmrpc (TEE daemon KeyMint needs).
service decrypt-qseecomd /system/bin/hal_run.sh /vendor/bin/qseecomd
    socket notify-topology stream 660 system drmrpc
    class main
    user root
    group root drmrpc
    seclabel u:r:recovery:s0
    disabled

# KeyMint - stock user system, group system drmrpc.
service decrypt-keymint /system/bin/hal_run.sh /vendor/bin/hw/android.hardware.security.keymint-service
    class main
    user system
    group system drmrpc
    seclabel u:r:recovery:s0
    disabled

# keystore2 - from the dump, DB dir /tmp/misc/keystore (matches TWRP's keystore2.rc).
service decrypt-keystore2 /system/bin/hal_run.sh /decrypt/system/bin/keystore2 /tmp/misc/keystore
    class main
    user root
    group root readproc log
    seclabel u:r:recovery:s0
    disabled

# vold - THE decrypt driver. init creates its sockets and passes the OPEN fds. The
# `knoxnative` socket is the one whose absence killed a bare vold launch
# ("fail to get knoxnative socket -> Critical error occured. close.").
service decrypt-vold /system/bin/hal_run.sh /decrypt/system/bin/vold --blkid_context=u:r:recovery:s0 --blkid_untrusted_context=u:r:recovery:s0 --fsck_context=u:r:recovery:s0 --fsck_untrusted_context=u:r:recovery:s0
    socket vold stream 0660 root mount
    socket cryptd stream 0660 root mount
    socket knoxnative stream 0660 root root
    class core
    user root
    group root mount
    seclabel u:r:recovery:s0
    disabled


   


